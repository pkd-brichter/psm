---
// Shell – linke Sidebar-Navigation der Pestalozzi-Plattform
// Icons + Namen immer sichtbar (nicht ein-/ausklappbar). Bereichswechsel via data-section.
---

<aside data-region="shell" class="app-sidebar d-none no-print">
  <a class="sidebar-brand" href="#" id="brand-link">
    <i class="bi bi-leaf-fill" style="color: var(--color-primary);"></i>
    <div class="brand-copy">
      <span class="brand-title" id="brand-title">Pflanzenschutz</span>
      <span class="brand-tagline" id="brand-tagline"></span>
    </div>
  </a>

  <span id="offline-indicator" class="d-none sidebar-offline">
    <i class="bi bi-wifi-off me-1"></i>Offline
  </span>

  <nav class="sidebar-nav">
    <button class="nav-btn" data-section="dashboard">
      <i class="bi bi-grid-1x2"></i><span>Start</span>
    </button>
    <button class="nav-btn" data-section="calc">
      <i class="bi bi-pencil-square"></i><span>Neu erfassen</span>
    </button>
    <button class="nav-btn" data-section="documentation">
      <i class="bi bi-list-ul"></i><span>Übersicht</span>
    </button>
    <button class="nav-btn" data-section="lager">
      <i class="bi bi-box-seam"></i><span>PSM-Lager</span>
    </button>
    <button class="nav-btn" data-section="acker">
      <i class="bi bi-map"></i><span>Acker-Planer</span>
    </button>
    <button class="nav-btn" data-section="settings">
      <i class="bi bi-gear"></i><span>Einstellungen</span>
    </button>
  </nav>

  <div class="sidebar-foot">
    <a
      href="https://info.digitale-psm.de"
      target="_blank"
      rel="noopener noreferrer"
      title="Info & Lizenz"
    >
      <i class="bi bi-info-circle me-1"></i>Info
    </a>
    <div class="d-flex align-items-center gap-2">
      <small id="app-version" class="text-muted"></small>
      <button
        type="button"
        class="monitor-toggle"
        data-action="debug-overlay-toggle"
        title="Performance Monitor aktivieren"
      >
        <i class="bi bi-activity"></i>
      </button>
    </div>
  </div>
</aside>

<style>
  .monitor-toggle {
    border: none;
    background: var(--color-surface-2);
    color: var(--color-text-muted);
    border-radius: var(--radius-full);
    padding: 0.15rem 0.5rem;
    font-size: 0.85rem;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }
  .monitor-toggle:hover,
  .monitor-toggle[data-active="true"] {
    background: var(--color-primary-subtle);
    color: var(--color-primary);
  }
  @media print {
    .no-print {
      display: none !important;
    }
  }
</style>
