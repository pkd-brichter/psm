---
// Shell – schmale, icon-basierte Bereichs-Sidebar (Portainer-Stil).
// Sidebar = NUR Bereichswechsel (data-area). Die zu einem Bereich gehörenden
// Unter-Ansichten erscheinen oben im Header (siehe index.astro [data-region="topnav"]),
// befüllt durch shellClient.ts.
---

<aside data-region="shell" class="app-sidebar d-none no-print">
  <a class="sidebar-brand" href="#" id="brand-link" data-area="start" title="Start">
    <i class="bi bi-leaf-fill" style="color: var(--color-primary);"></i>
  </a>

  <nav class="sidebar-nav">
    <button class="nav-btn" data-area="start" title="Start" aria-label="Start">
      <i class="bi bi-grid-1x2"></i>
    </button>
    <button class="nav-btn" data-area="psm" title="PSM – Pflanzenschutz" aria-label="PSM">
      <i class="bi bi-flower1"></i>
    </button>
    <button class="nav-btn" data-area="acker" title="Acker-Planer" aria-label="Acker-Planer">
      <i class="bi bi-map"></i>
    </button>
    <button class="nav-btn nav-btn-share" data-action="share-data" title="Daten teilen" aria-label="Daten teilen">
      <i class="bi bi-share"></i>
      <span class="nav-badge d-none" data-role="share-badge"></span>
    </button>
  </nav>

  <div class="sidebar-foot">
    <a
      href="https://info.digitale-psm.de"
      target="_blank"
      rel="noopener noreferrer"
      title="Info & Lizenz"
      aria-label="Info & Lizenz"
    >
      <i class="bi bi-info-circle"></i>
    </a>
  </div>
</aside>

<style>
  @media print {
    .no-print {
      display: none !important;
    }
  }

  /* Mobile-Modus: schlanker Erfassungs-Client. Acker/Einstellungen aus,
     dafür "Daten teilen" sichtbar. Desktop bleibt unverändert. */
  .nav-btn-share {
    display: none;
  }
  :global(body.mobile-mode) .nav-btn-share {
    display: flex;
    position: relative;
  }
  /* Hinweis "noch nicht geteilt": Zähler-Badge + Akzentfarbe am Teilen-Button */
  .nav-btn-share.has-unshared {
    background: var(--warning-600, #d97706);
    color: #000;
  }
  .nav-badge {
    position: absolute;
    top: 1px;
    right: 1px;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    border-radius: 999px;
    background: #ef4444;
    color: #fff;
    font-size: 0.62rem;
    font-weight: 700;
    line-height: 16px;
    text-align: center;
  }
  :global(body.mobile-mode) .nav-btn[data-area="acker"],
  :global(body.mobile-mode) .nav-btn[data-area="settings"] {
    display: none;
  }
</style>
