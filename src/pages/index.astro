---
import BaseLayout from '../layouts/BaseLayout.astro';
import Shell from '../components/Shell.astro';
---

<BaseLayout>
  <div data-region="startup"></div>
  <Shell />
  
  <main data-region="main" class="main-content d-none">
    <header data-region="topnav" class="app-topnav no-print">
      <div class="topnav-context">
        <i class="bi topnav-area-icon" id="topnav-area-icon" aria-hidden="true"></i>
        <span class="topnav-area-label" id="topnav-area-label"></span>
        <span id="offline-indicator" class="d-none topnav-offline">
          <i class="bi bi-wifi-off me-1"></i>Offline
        </span>
      </div>
      <nav class="topnav-tabs" id="topnav-tabs" aria-label="Ansichten"></nav>
      <div class="topnav-meta">
        <div class="topnav-brand">
          <span class="brand-title" id="brand-title"></span>
          <span class="brand-tagline" id="brand-tagline"></span>
        </div>
        <small id="app-version" class="text-muted"></small>
      </div>
    </header>
    <div class="container py-4">
      <!-- Dashboard / Start Section (Standard-Ansicht) -->
      <div id="section-dashboard" class="content-section" style="display: block;">
        <div class="section-container">
          <div data-feature="dashboard"></div>
        </div>
      </div>

      <!-- Calculation Section -->
      <div id="section-calc" class="content-section" style="display: none;">
        <div class="section-container">
          <div data-feature="calculation"></div>
        </div>
      </div>

      <!-- Documentation Section -->
      <div id="section-documentation" class="content-section" style="display: none;">
        <div class="section-container">
          <div data-feature="documentation"></div>
        </div>
      </div>

      <!-- Mittel-Lager Section -->
      <div id="section-lager" class="content-section" style="display: none;">
        <div class="section-container">
          <div data-feature="lager"></div>
        </div>
      </div>

      <!-- Acker-Planer Section -->
      <div id="section-acker" class="content-section" style="display: none;">
        <div class="section-container">
          <div data-feature="acker"></div>
        </div>
      </div>

      <!-- Settings Section (includes Mittel, GPS, EPPO/BBCH, BVL) -->
      <div id="section-settings" class="content-section" style="display: none;">
        <div class="section-container">
          <div data-feature="settings"></div>
        </div>
      </div>
      

    </div>
  </main>
  
  <style>
    .main-content > .container {
      padding-top: 1.25rem;
    }
    
    .content-section {
      animation: fadeIn 0.3s ease-in;
    }
    
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
  </style>
</BaseLayout>
