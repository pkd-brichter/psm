---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Mobil">
  <div class="m-app">
    <header class="m-header no-print">
      <div class="m-top">
        <span class="m-brand"><i class="bi bi-flower1"></i> PSM <small>mobil</small></span>
        <a class="m-desktop-link" href="../">Desktop &rarr;</a>
      </div>
      <div class="m-share-bar" data-role="m-share-status"></div>
    </header>

    <main class="m-main">
      <label class="m-device">
        <span class="m-device-label">Dieses Gerät (erscheint beim Import am PC)</span>
        <input type="text" class="form-control" data-role="m-device-label" placeholder="z. B. Handy Abbas" />
      </label>

      <div data-feature="calculation"></div>
    </main>
  </div>

  <script>
    import '@/scripts/pages/mobileClient.ts';
  </script>
</BaseLayout>

<style is:global>
  body.m-page .app-root {
    display: block;
    min-height: 100vh;
  }
  .m-app {
    max-width: 760px;
    margin: 0 auto;
    padding-bottom: 3rem;
  }
  .m-header {
    position: sticky;
    top: 0;
    z-index: 30;
    background: var(--color-surface-1, #0f172a);
    border-bottom: 1px solid var(--color-border, rgba(255, 255, 255, 0.1));
    padding: 10px 14px;
  }
  .m-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }
  .m-brand {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-text);
  }
  .m-brand i {
    color: var(--color-primary, #22c55e);
  }
  .m-brand small {
    font-weight: 400;
    opacity: 0.55;
    font-size: 0.7rem;
    margin-left: 2px;
  }
  .m-desktop-link {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .m-share-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .m-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .m-pill-warn {
    background: var(--warning-600, #d97706);
    color: #000;
  }
  .m-pill-ok {
    background: rgba(34, 197, 94, 0.15);
    color: var(--color-primary, #22c55e);
  }
  .m-share-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 18px;
    border: none;
    border-radius: 9px;
    background: var(--color-primary, #22c55e);
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
  }
  .m-share-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
  .m-main {
    padding: 14px;
  }
  .m-device {
    display: block;
    margin-bottom: 16px;
  }
  .m-device .m-device-label {
    display: block;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 4px;
  }
</style>
